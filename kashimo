local function applyDesc(char)local hum=char:WaitForChild("Humanoid")local bf=Instance.new("BindableFunction")local answered=Instance.new("BindableEvent")local choice=false bf.OnInvoke=function(btn)choice=btn=="Yes"answered:Fire()end game:GetService("StarterGui"):SetCore("SendNotification",{Title="Switch avatar?",Text="Please confirm your choice.",Duration=15,Button1="Yes",Button2="No",Callback=bf})answered.Event:Wait()bf:Destroy()answered:Destroy()if not choice then return end for _,v in pairs(char:GetChildren())do if v:IsA("Accessory")or v:IsA("Shirt")or v:IsA("Pants")or v:IsA("ShirtGraphic")then v:Destroy()end end pcall(function()hum.BodyTypeScale=desc.BodyTypeScale hum.BodyWidthScale=desc.WidthScale hum.BodyHeightScale=desc.HeightScale hum.BodyDepthScale=desc.DepthScale hum.HeadScale=desc.HeadScale hum.ProportionScale=desc.ProportionScale end)pcall(function()local head=char:FindFirstChild("Head")if head then local mesh=head:FindFirstChildOfClass("SpecialMesh")if mesh and desc.Head~=0 then local objs=game:GetObjects("rbxassetid://"..desc.Head)for _,obj in pairs(objs)do if obj:IsA("SpecialMesh")then mesh.MeshId=obj.MeshId mesh.TextureId=obj.TextureId mesh.Scale=obj.Scale end end end end end)local map={["Head"]=desc.HeadColor,["Torso"]=desc.TorsoColor,["Left Arm"]=desc.LeftArmColor,["Right Arm"]=desc.RightArmColor,["Left Leg"]=desc.LeftLegColor,["Right Leg"]=desc.RightLegColor}for name,color in pairs(map)do local part=char:FindFirstChild(name)if part then pcall(function()part.Color=color end)end end pcall(function()local head=char:FindFirstChild("Head")if head then local decal=head:FindFirstChild("face")if decal then decal.Texture="rbxassetid://"..desc.Face end end end)pcall(function()if desc.Shirt~=0 then local objs=game:GetObjects("rbxassetid://"..desc.Shirt)for _,obj in pairs(objs)do if obj:IsA("Shirt")then obj.Parent=char end end end end)pcall(function()if desc.Pants~=0 then local objs=game:GetObjects("rbxassetid://"..desc.Pants)for _,obj in pairs(objs)do if obj:IsA("Pants")then obj.Parent=char end end end end)pcall(function()if desc.GraphicTShirt~=0 then local objs=game:GetObjects("rbxassetid://"..desc.GraphicTShirt)for _,obj in pairs(objs)do if obj:IsA("ShirtGraphic")then obj.Parent=char end end end end)local function weld(obj)local h=obj:FindFirstChild("Handle")if not h then return end h.Anchored=false h.CanCollide=false for _,w in pairs(h:GetChildren())do if w:IsA("Weld")or w:IsA("WeldConstraint")or w:IsA("Motor6D")or w:IsA("RigidConstraint")then w:Destroy()end end obj.Parent=char task.wait(0.1)local ha=h:FindFirstChildOfClass("Attachment")if ha then for _,part in pairs(char:GetChildren())do if part:IsA("BasePart")then for _,att in pairs(part:GetChildren())do if att:IsA("Attachment")and att.Name==ha.Name then local rc=Instance.new("RigidConstraint")rc.Attachment0=att rc.Attachment1=ha rc.Parent=h return end end end end end local head=char:FindFirstChild("Head")if head then local w=Instance.new("WeldConstraint")w.Part0=head w.Part1=h w.Parent=h h.CFrame=head.CFrame*CFrame.new(0,0.5,0)end end for _,acc in pairs(desc:GetAccessories(true))do pcall(function()for _,obj in pairs(game:GetObjects("rbxassetid://"..acc.AssetId))do if obj:IsA("Accessory")then weld(obj)end end end)end end
